# ============================================================================
# Microsoft Enterprise MCP Servers - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For mock mode (no Azure credentials required), set USE_MOCK_DATA=true
# ============================================================================

# --- General ---
USE_MOCK_DATA=true

# --- Azure Subscription (required for Azure MCP Server) ---
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_RESOURCE_GROUP=contoso-monitoring

# --- Azure Monitor / Log Analytics (Scenarios 1, 3, 5) ---
LOG_ANALYTICS_WORKSPACE_ID=your-log-analytics-workspace-id

# --- Azure DevOps (Scenarios 1, 3, 5) ---
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/contoso-org
AZURE_DEVOPS_PROJECT=ContosoApp
AZURE_DEVOPS_PAT=your-personal-access-token

# --- Cosmos DB (Scenario 5) ---
COSMOS_DB_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-key

# --- Azure OpenAI (Scenarios 3 & 5 — Multi-Agent with Semantic Kernel) ---
# Required when running:
#   python agents/incident_remediation.py --real   (Scenario 3 — Handoff)
#   python agents/velocity_analysis.py --real      (Scenario 5 — Sequential)
AZURE_OPENAI_ENDPOINT=https://your-aoai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_KEY=your-api-key  # Only if not using DefaultAzureCredential
