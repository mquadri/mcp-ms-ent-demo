# ============================================================================
# Microsoft Enterprise MCP Servers - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For mock mode (no Azure credentials required), set USE_MOCK_DATA=true
# ============================================================================

# --- General ---
USE_MOCK_DATA=true

# --- Azure Subscription ---
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=contoso-monitoring
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# --- Azure Monitor / Log Analytics (Scenario 1) ---
LOG_ANALYTICS_WORKSPACE_ID=your-log-analytics-workspace-id

# --- Azure DevOps (Scenarios 1 & 5) ---
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/contoso-org
AZURE_DEVOPS_PROJECT=ContosoApp
AZURE_DEVOPS_PAT=your-personal-access-token

# --- Cosmos DB (Scenario 5) ---
COSMOS_DB_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-key

# --- Microsoft Graph (Scenario 1) ---
# Uses AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET above
